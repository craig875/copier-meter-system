# Database
DATABASE_URL="postgresql://user:password@localhost:5432/copier_meter_db"

# Server
PORT=3001
NODE_ENV=development
# Behind nginx: defaults to on in production (trust first hop). Set TRUST_PROXY=false if Node is exposed directly.
# TRUST_PROXY=true

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Frontend (CORS) — browser origin(s) that may call the API
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated extra origins (www vs apex, http + https during migration)
# FRONTEND_URLS=http://www.example.com,https://example.com,https://www.example.com

# Connectivity Monitoring (optional - set CONNECTIVITY_MODULE_ENABLED=false to disable)
CONNECTIVITY_MODULE_ENABLED=true
CONNECTIVITY_PING_INTERVAL_MS=60000
CONNECTIVITY_CONCURRENT_PINGS=15
CONNECTIVITY_ALERT_RATE_LIMIT=10

# SMTP for connectivity alerts (optional - alerts skipped if not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=your-smtp-password
ALERT_FROM_EMAIL=alerts@example.com
